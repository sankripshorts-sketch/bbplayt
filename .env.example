# Скопируйте в .env. Базовый хост API (документ BLACKBEARS / iCafe).
EXPO_PUBLIC_API_BASE_URL=https://vibe.blackbearsplay.ru

# Новости VK: числовой id группы (из ссылки club… или настроек). По умолчанию в коде — bbplay__tmb (Тамбов).
# EXPO_PUBLIC_VK_GROUP_ID=221562447
# Экран «Новости» открывает мобильную стену в WebView. Переопределить полный URL (m.vk.com/…):
# EXPO_PUBLIC_VK_M_URL=https://m.vk.com/club221562447
# Полный URL десктопной ленты (для старых утилит парсинга / кастомных сценариев):
# EXPO_PUBLIC_VK_FEED_CUSTOM_URL=https://vk.com/club221562447
#
# Прокси для загрузки HTML стены (обход CORS в Expo Web и при необходимости на сервере).
# Шаблон: ваш эндпоинт подставляет URL вместо {{url}} (подставляется encodeURIComponent полной ссылки на vk.com).
# Пример: EXPO_PUBLIC_VK_WALL_PROXY_TEMPLATE=https://api.example.com/vk-html?target={{url}}

# Подпись MD5 для POST /verify (SMS) и POST /booking — как SECRET_KEY в реф. Android (build.gradle.kts).
# В app.config.js уже задано значение по умолчанию; при смене бэкенда переопределите:
# EXPO_PUBLIC_VERIFY_SIGN_SECRET=
# EXPO_PUBLIC_BOOKING_SIGN_SECRET=
#
# Режим подписи POST /booking (поле key). По умолчанию android — как реф. APK.
#   android       — MD5(memberId + randKey + privateKey + secret); нужны секрет и private_key из логина
#   rand_secret   — MD5(randKey + secret); private_key не используется
#   legacy_concat — устаревший MD5 от полей брони (без секрета)
# EXPO_PUBLIC_BOOKING_KEY_MODE=android
#
# Считать успехом POST /booking только при code без тела ответа (как старый Android). По умолчанию выключено:
# нужны поля брони в ответе, иначе показывается ошибка.
# EXPO_PUBLIC_BOOKING_LOOSE_SUCCESS=1
#
# Имя ПК в POST /booking: по умолчанию в lower-case; если бронь не проходит — попробуйте исходный регистр с API:
# EXPO_PUBLIC_BOOKING_PRESERVE_PC_NAME_CASE=1

# Схема зала (после привязки к bbox structRooms): доп. сдвиг всех зон в px (отрицательное X — влево, отрицательное Y — вверх).
# EXPO_PUBLIC_HALL_MAP_OFFSET_X=0
# EXPO_PUBLIC_HALL_MAP_OFFSET_Y=0
# Поправка «кривых» координат iCafe по осям (после scale=canvasW/maxX; 1 = без изменений). Унифицированный множитель на все координаты не подходит — нужны раздельные kx/ky.
# EXPO_PUBLIC_HALL_MAP_AXIS_SCALE_X=1
# EXPO_PUBLIC_HALL_MAP_AXIS_SCALE_Y=1
# Переопределение по клубу (iCafe id), только указанные оси: {"12345":{"x":1.02,"y":0.98}}
# EXPO_PUBLIC_HALL_MAP_CLUB_AXIS_SCALE_JSON=
# Поправка по клубу (iCafe id из API), JSON-объект: {"12345":{"x":-2,"y":1}}
# EXPO_PUBLIC_HALL_MAP_CLUB_OFFSETS_JSON=
# Сдвиг отдельной зоны по имени из structRooms (например GameZone влево к Bootcamp), px: {"GameZone":{"x":-160}}
# Переопределяет встроенный небольшой сдвиг GameZone в приложении.
# EXPO_PUBLIC_HALL_MAP_ZONE_OFFSETS_JSON=
# Доп. масштаб зоны по осям X/Y после базовой шкалы клуба, ключи как у зон (сжатое имя): {"gamezone":{"x":1.02,"y":0.98}}
# EXPO_PUBLIC_HALL_MAP_ZONE_XY_SCALE_JSON=
# Сдвиг чипа ПК в px на холсте (после геометрии зоны): {"pc09":{"x":2,"y":-3}}
# EXPO_PUBLIC_HALL_MAP_PC_OFFSETS_JSON=
# Множитель размера чипа ПК (1 = по умолчанию): {"pc09":1.08}
# EXPO_PUBLIC_HALL_MAP_PC_SCALE_JSON=

# SMS после регистрации: сначала request-sms, при HTTP 404 — requestsms (или свой путь первым через EXPO_PUBLIC_REQUEST_SMS_PATH).
# Тело по умолчанию: { member_id, member_phone }. Только member_id (как в минимальной доке iCafe): EXPO_PUBLIC_REQUEST_SMS_INCLUDE_PHONE=0
# EXPO_PUBLIC_REQUEST_SMS_PATH=request-sms
# EXPO_PUBLIC_REQUEST_SMS_INCLUDE_PHONE=0

# Список броней: по умолчанию /all-books-cafes (см. app.config.js). При необходимости:
# EXPO_PUBLIC_ALL_BOOKS_PATH=/all-books-member

# Пополнение: POST .../members/action/topup — по умолчанию topup_ids = member id (как api.icafecloud.com).
# Режим прокси BLACKBEARS с каталогом: в topup_ids — product_id из GET /all-prices-icafe:
# EXPO_PUBLIC_TOPUP_IDS_USE_PRODUCT_ID=1
# Требовать product_id без отката на member id: EXPO_PUBLIC_TOPUP_STRICT_PRODUCT_ID=1
#
# Поле промокода в теле fetchBonus/topup (если бэкенд ждёт другое имя).
# EXPO_PUBLIC_TOPUP_PROMO_FIELD=promo_code
#
# По умолчанию topup идёт с Authorization: Bearer (как GET members). Если прокси ждёт только private_key в теле без Bearer:
# EXPO_PUBLIC_TOPUP_WITHOUT_BEARER=1
#
# При «Member not found» на topup в тело добавляются member_account, icafe_id, member_icafe_id (из сессии логина).
# Дополнительно (экспериментально): EXPO_PUBLIC_TOPUP_INCLUDE_COMPOSITE_ID=1 — поле member_id_icafe_id
# или EXPO_PUBLIC_TOPUP_USE_COMPOSITE_AS_MEMBER_ID=1 — подставить составной id вместо member_id
# Если прокси ругается на лишние поля: EXPO_PUBLIC_TOPUP_MINIMAL_BODY=1
# По умолчанию member_id в topup — строка. Число в JSON: EXPO_PUBLIC_TOPUP_MEMBER_ID_AS_NUMBER=1
#
# Сохранение профиля: iCafe Cloud PUT `/api/v2/cafe/{cafeId}/members/{memberId}` — в теле также member_account (логин) и member_id;
# числовой member_id в JSON: EXPO_PUBLIC_PUT_MEMBER_ID_AS_NUMBER=1
#
# Сообщение «Api not allowed» при сохранении профиля / разделах статистики: на прокси iCafe должны быть
# разрешены соответствующие пути для клиента с сессией (Authorization: Bearer после логина).
#
# Пополнение: по умолчанию страница на том же хосте, что API — {apiBaseUrl}/bbplay/ru
# Укажите URL страницы оплаты на вашем прокси; иначе WebView может увести в маркет «оригинального» приложения.
# Полный URL (другой домен / лендинг): EXPO_PUBLIC_TOP_UP_URL=https://bbgms.link/bbplay/ru
# Только путь на своём API: EXPO_PUBLIC_TOP_UP_PATH=bbplay/ru
#
# Подписи MD5 для POST verify и POST booking должны совпадать с SECRET на сервере-прокси (как в реф. Android):
# EXPO_PUBLIC_VERIFY_SIGN_SECRET=
# EXPO_PUBLIC_BOOKING_SIGN_SECRET=

# --- Доступ к API iCafe (v2) через прокси vibe ---
# Сообщения вида «Api not allowed» / HTTP 403 означают: для клиента с вашим токеном на прокси
# не открыт соответствующий путь. Это настраивается на сервере BlackBears, не в приложении.
# Типичные методы, которые без явного разрешения на шлюзе недоступны:
#   POST .../members/action/topup          — зачисление (пополнение)
#   POST .../members/action/fetchBonus     — предпросмотр бонуса к пополнению
#   PUT  .../members/{memberId}            — сохранение профиля (iCafe Cloud)
# История/сессии в приложении по умолчанию идут на прокси vibe (docs/API_VIBE_LOGIC.md):
#   GET  .../memberBalanceHistory?member_id=&page=
#   POST .../pcSessions  (тело member_id, page)
# Прямой iCafe Cloud (https://api.icafecloud.com — см. dev.icafecloud.com/docs):
#   EXPO_PUBLIC_ICAFE_API_BASE_URL=https://api.icafecloud.com
#   EXPO_PUBLIC_INSIGHTS_USE_ICAFE_CLOUD_PATHS=1
#   EXPO_PUBLIC_ICAFE_CLOUD_API_KEY=<ключ из лицензии iCafe Cloud; заголовок Authorization: Bearer — не токен POST /login>
#   GET  .../members/{memberId}/balanceHistory — движения по счёту (пагинация page)
#   GET  .../pcSessions/{memberId}/memberSessionHistory — игровые сессии
#   GET  .../memberOrders                  — заказы
#   GET  /customer-analysis                — аналитика
#   GET  .../members/action/rankingUrl     — рейтинг
# Ключи в .env не «открывают» эти методы сами по себе — нужна выдача прав на стороне API.
# Резерв: одна ссылка (ЛК/статистика на сайте), кнопка под ошибкой в разделах рейтинг/аналитика/история:
# EXPO_PUBLIC_INSIGHTS_FALLBACK_URL=https://vibe.blackbearsplay.ru/bbplay/ru
