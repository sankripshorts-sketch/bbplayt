<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profile_loading_balance"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_upper_corners"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <View
        android:id="@+id/profile_loading1"
        android:layout_width="68dp"
        android:layout_height="8dp"
        android:layout_marginTop="33dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/profile_loading2"
        android:layout_width="50dp"
        android:layout_height="10dp"
        android:layout_marginTop="26dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintBottom_toBottomOf="@+id/view"
        app:layout_constraintStart_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view" />

    <!--region Данный блок с бонусами скрыт т.к.
        они сами не знают чего хотят.
        Пока его оставлю вдруг надо будет вернуть-->
    <View
        android:id="@+id/profile_loading3"
        android:layout_width="68dp"
        android:layout_height="8dp"
        android:layout_marginTop="37dp"
        android:background="@drawable/dr_loading_field"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <View
            android:id="@+id/profile_loading4"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/oval_loading"
            app:layout_constraintCircleRadius="100dp"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/profile_loading5"
            android:layout_width="50dp"
            android:layout_height="10dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:background="@drawable/dr_loading_field" />
    </LinearLayout>
    <!--endregion-->
</LinearLayout>