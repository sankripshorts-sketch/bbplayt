<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="@font/din_round_pro_medium"
        android:drawablePadding="8dp"
        android:layout_gravity="center"
        android:text="@string/choice_place_text"
        android:textColor="@color/grey_light"
        android:textSize="20sp"
        app:drawableStartCompat="@drawable/ic_pc_image" />

    <mobi.blackbears.bbplay.screens.booking.view.AreasPcView
        android:id="@+id/view_areas"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="@color/grey_dark" />

    <LinearLayout
        android:id="@+id/areas_description_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/grey_dark"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="11dp">

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="4dp"
            android:fontFamily="@font/din_round_pro_bold"
            android:text="@string/free_pc_text"
            android:textColor="@color/grey_light"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_pc_state" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:drawablePadding="4dp"
            android:fontFamily="@font/din_round_pro_bold"
            android:text="@string/busy_pc_text"
            android:textColor="@color/grey_light"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_pc_busy_state" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:drawablePadding="4dp"
            android:fontFamily="@font/din_round_pro_bold"
            android:text="@string/selected_pc_text"
            android:textColor="@color/grey_light"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_pc_state"
            app:drawableTint="@color/pc_selected" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:drawablePadding="4dp"
            android:fontFamily="@font/din_round_pro_bold"
            android:text="@string/disabled_pc_text"
            android:textColor="@color/grey_light"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_pc_state"
            app:drawableTint="@color/pc_disabled_color" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>