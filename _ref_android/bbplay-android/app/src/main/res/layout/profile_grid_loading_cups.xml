<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rectangle_grey"
    android:columnCount="2"
    android:padding="24dp"
    android:rowCount="2">

    <View
        android:id="@+id/profile_loading6"
        android:layout_width="68dp"
        android:layout_height="8dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </View>

    <View
        android:id="@+id/profile_loading7"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/oval_loading"
        app:layout_constraintCircleRadius="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/profile_loading6">

    </View>

    <View
        android:id="@+id/profile_loading10"
        android:layout_width="50dp"
        android:layout_height="10dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintBottom_toBottomOf="@+id/profile_loading7"
        app:layout_constraintStart_toEndOf="@+id/profile_loading7"
        app:layout_constraintTop_toTopOf="@+id/profile_loading7" />

    <View
        android:id="@+id/profile_loading8"
        android:layout_width="68dp"
        android:layout_height="6dp"
        android:layout_marginEnd="13dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintBottom_toBottomOf="@+id/profile_loading11"
        app:layout_constraintEnd_toStartOf="@+id/profile_loading11">

    </View>

    <View
        android:id="@+id/profile_loading9"
        android:layout_width="68dp"
        android:layout_height="6dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="13dp"
        android:background="@drawable/dr_loading_field"
        app:layout_constraintEnd_toStartOf="@+id/profile_loading11"
        app:layout_constraintTop_toTopOf="@+id/profile_loading11">

    </View>

    <ImageView
        android:id="@+id/profile_loading11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_to_table"
        android:backgroundTint="@color/grey_700"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"></ImageView>


</androidx.constraintlayout.widget.ConstraintLayout>