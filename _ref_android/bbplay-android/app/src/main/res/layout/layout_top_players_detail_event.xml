<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_top_players"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/din_round_pro_bold"
        android:text="@string/top_players_text"
        android:layout_marginStart="24dp"
        android:textColor="@color/white"
        android:textSize="28sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/options_top"
        layout="@layout/layout_title_rank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="6dp"
        app:layout_constraintEnd_toEndOf="@+id/tv_top_players"
        app:layout_constraintStart_toStartOf="@+id/tv_top_players"
        app:layout_constraintTop_toBottomOf="@+id/tv_top_players" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_top_players"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintEnd_toEndOf="@+id/options_top"
        app:layout_constraintStart_toStartOf="@+id/options_top"
        app:layout_constraintTop_toBottomOf="@+id/options_top"
        tools:listitem="@layout/item_rank" />
</androidx.constraintlayout.widget.ConstraintLayout>