<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="24dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/bt_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:paddingEnd="20dp"
            android:src="@drawable/ic_back_nav"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pay_balance"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:fontFamily="@font/din_round_pro_bold"
            android:textSize="28sp" />



        <Space
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.1"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeColor="@color/green"
            app:boxBackgroundColor="@android:color/transparent"
            app:helperText="@string/input_help_pay"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="72dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_summa_fragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/din_round_pro_bold"
                android:gravity="start"
                android:text="@string/one_hundred_text"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:textSize="32sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:scrollbarThumbHorizontal="@null">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_two_hundred"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="15dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_rectangle_corner_4dp"
                    android:backgroundTint="@color/grey_500"
                    android:fontFamily="@font/din_round_pro_medium"
                    android:gravity="center"
                    android:lines="1"
                    android:text="@string/two_hundred_rubles"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_three_hundred"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="15dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_rectangle_corner_4dp"
                    android:backgroundTint="@color/grey_500"
                    android:fontFamily="@font/din_round_pro_medium"
                    android:gravity="center"
                    android:lines="1"
                    android:text="@string/three_hundred_rubles"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_four_hundred"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="15dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_rectangle_corner_4dp"
                    android:backgroundTint="@color/grey_500"
                    android:fontFamily="@font/din_round_pro_medium"
                    android:gravity="center"
                    android:lines="1"
                    android:text="@string/four_hundred_rubles"
                    android:textColor="@color/white"
                    android:textSize="20sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_ok_pay"
            style="@style/BBPlay.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="32dp"
            android:text="@string/replenish_text" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.3"/>
    </LinearLayout>

    <include layout="@layout/layout_progress_bar"
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</FrameLayout>