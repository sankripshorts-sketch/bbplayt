<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_news_comments"
        style="@style/BBPlay.ButtonsItemNewsStyle"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_weight="1"
        app:icon="@drawable/ic_news_comment"
        app:iconPadding="6dp"
        tools:text="14" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_news_images"
        style="@style/BBPlay.ButtonsItemNewsStyle"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginStart="9dp"
        android:layout_weight="1"
        android:visibility="gone"
        app:icon="@drawable/ic_news_image"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        tools:text="5"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_news_link"
        style="@style/BBPlay.ButtonsItemNewsStyle"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginStart="9dp"
        android:layout_weight="1"
        android:visibility="gone"
        app:icon="@drawable/ic_news_link"
        app:iconGravity="textStart"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_news_poll"
        style="@style/BBPlay.ButtonsItemNewsStyle"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginStart="9dp"
        android:layout_weight="1"
        android:visibility="gone"
        app:icon="@drawable/ic_news_poll"
        app:iconGravity="textStart"
        tools:visibility="visible" />
</LinearLayout>