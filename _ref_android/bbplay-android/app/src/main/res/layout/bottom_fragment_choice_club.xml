<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="45dp"
    android:paddingBottom="51dp"
    tools:background="@color/background">

    <TextView
        android:id="@+id/tv_choice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/din_round_pro_medium"
        android:gravity="center"
        android:text="@string/choice_club_description_text"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="@+id/header_check_address"
        app:layout_constraintStart_toStartOf="@+id/header_check_address"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/header_check_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_choice">

        <TextView
            android:id="@+id/rb_first_club"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_personal_info"
            android:fontFamily="@font/din_round_pro_bold"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:drawableEndCompat="@drawable/shape_btn_radio_on"
            tools:text="Советская 121" />

        <TextView
            android:id="@+id/new_club"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_personal_info"
            android:fontFamily="@font/din_round_pro_bold"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text="@string/address_two_text"
            android:textColor="@color/grey_light"
            android:textSize="18sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_soon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:contentDescription="@null"
        android:src="@drawable/bg_soon"
        app:layout_constraintBottom_toBottomOf="@+id/header_check_address"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/din_round_pro_bold"
        android:text="@string/soon"
        android:textColor="@color/white"
        android:textSize="16dp"
        app:layout_constraintEnd_toEndOf="@+id/iv_soon"
        app:layout_constraintStart_toStartOf="@+id/iv_soon"
        app:layout_constraintTop_toTopOf="@+id/iv_soon" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bt_select_location"
        style="@style/BBPlay.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:text="@string/save"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_check_address" />

</androidx.constraintlayout.widget.ConstraintLayout>