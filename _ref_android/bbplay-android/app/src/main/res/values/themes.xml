<resources>
    <!-- Base application theme. -->
    <style name="Theme.BBPlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.BBSplash" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/bg_splash_screen</item>
        <item name="postSplashScreenTheme">@style/PrimaryTheme.BBPlay</item>
    </style>
    
    <style name="PrimaryTheme.BBPlay" parent="Theme.BBPlay">
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorSecondary">@color/green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/background</item>
        <item name="colorOnSurface">@color/grey_light</item>
        <item name="android:statusBarColor">?attr/colorOnPrimary</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="bottomSheetDialogTheme">@style/BBPlay.BottomSheetDialogTheme</item>
    </style>

    <style name="BBPlay.NumberPickerTheme" parent="PrimaryTheme.BBPlay">
        <item name="colorControlNormal">@color/transparent</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">@font/din_round_pro_bold</item>
    </style>
</resources>