<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="BbTextLayoutWithEditTextView">
        <attr name="hintText" format="string" />
        <attr name="iconStart" format="reference" />
        <attr name="typeInEdit" format="flags">
            <!--Corresponds to {@link android.text.InputType#TYPE_CLASS_PHONE}. -->
            <flag name="phone" value="0x00000003" />
            <!-- Corresponds to
             {@link android.text.InputType#TYPE_CLASS_DATETIME} ||
             {@link android.text.InputType#TYPE_DATETIME_VARIATION_DATE}. -->
            <flag name="date" value="0x00000014" />
            <flag name="textNoSuggestions" value="0x00080001" />
            <flag name="textEmailAddress" value="0x00000021" />
            <flag name="textPassword" value="0x00000081" />
        </attr>
        <attr name="isEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="EnterVerificationCodeView">
        <attr name="codeLength" format="integer"/>
        <attr name="textSize" format="dimension"/>
        <attr name="textColor" format="color"/>
        <attr name="font" format="reference"/>
    </declare-styleable>

    <declare-styleable name="BonusBannerLine">
        <attr name="valueNameBgColor" format="color"/>
        <attr name="bonusAmountBgColor" format="color"/>
        <attr name="valueNameTextColor" format="color"/>
        <attr name="bonusAmountTextColor" format="color"/>
        <attr name="valueName" format="string"/>
        <attr name="bonusAmount" format="string"/>
    </declare-styleable>
</resources>